# Copy to `.env` for local dev (gitignored). For Fly.io, set via `fly secrets`.

# Mixpanel service-account creds (REQUIRED)
MIXPANEL_PROJECT_ID=
MIXPANEL_USERNAME=
MIXPANEL_SECRET=

# Creative Production Tracker — MongoDB source (OPTIONAL).
# When unset, the app boots fine and the creatives sync no-ops.
# MONGO_URI=mongodb://user:pass@host:port/?authSource=admin&directConnection=true
# MONGO_DB=test
# Product base URL for "View N tables" deep links (also editable on /config).
# PRODUCT_BASE_URL=https://staging.hawky.ai

# Flask session secret. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Leave unset locally; required in production.
FLASK_SECRET_KEY=

# --- Authentication -------------------------------------------------------
# Tier 1 (preferred): Google SSO restricted to @hawky.ai. When CLIENT_ID +
# CLIENT_SECRET are set, the whole dashboard is gated behind "Sign in with
# Google" and only allowed-domain accounts may enter. Create an OAuth 2.0
# Client (type: Web application) at https://console.cloud.google.com/apis/credentials
# and add the redirect URI:  https://<your-domain>/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated. Defaults to hawky.ai when unset.
GOOGLE_ALLOWED_DOMAINS=hawky.ai
# Optional per-email exceptions for non-hawky.ai addresses (comma-separated).
# GOOGLE_ALLOWED_EMAILS=contractor@example.com

# Tier 2 (fallback): HTTP Basic Auth, used only when Google OAuth is NOT
# configured. Leave both unset locally to disable auth entirely (open).
STREAKS_AUTH_USER=hawky
STREAKS_AUTH_PASSWORD=

# SQLite file location. Defaults to <project>/streaks.db locally.
# In Fly.io the volume mounts at /data, so this should be /data/streaks.db.
# STREAKS_DB_PATH=/data/streaks.db
